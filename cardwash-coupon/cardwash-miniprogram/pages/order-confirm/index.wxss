/* pages/order-confirm/index.wxss */
.confirm-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background-color: #f5f5f5;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fa8c16;
}

.card-body {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-row .desc {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
}

/* 支付金额 */
.amount-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.amount-value {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 32rpx;
  color: #ff4d4f;
  margin-right: 4rpx;
}

.price {
  font-size: 64rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* 温馨提示 */
.tips-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-info .label {
  font-size: 28rpx;
  color: #666;
}

.total-info .price-symbol {
  font-size: 32rpx;
  color: #ff4d4f;
  margin-right: 4rpx;
}

.total-info .price-value {
  font-size: 44rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.pay-btn {
  background-color: #1890FF;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
  border: none;
}
