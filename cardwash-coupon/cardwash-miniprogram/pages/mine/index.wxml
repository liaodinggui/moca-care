<!--pages/mine/index.wxml-->
<view class="mine-page">
  <!-- 用户信息 -->
  <view class="user-card" catchtap="editProfile" hover-class="user-card-hover" hover-stay-time="150">
    <view class="avatar">
      <image src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="user-info-wrap">
      <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="phone">{{userInfo.phone || '未绑定手机号'}}</view>
    </view>
  </view>

  <!-- 订单状态卡片 -->
  <view class="section-title">我的订单</view>
  <view class="order-cards">
    <view class="order-card" catchtap="goToOrderList" data-status="0">
      <view class="card-num {{pendingCount > 0 ? 'highlight' : ''}}">{{pendingCount}}</view>
      <view class="card-label">待付款</view>
    </view>
    <view class="order-card" catchtap="goToOrderList" data-status="1">
      <view class="card-num {{usingCount > 0 ? 'highlight' : ''}}">{{usingCount}}</view>
      <view class="card-label">使用中</view>
    </view>
    <view class="order-card" catchtap="goToOrderList" data-status="2">
      <view class="card-num {{completedCount > 0 ? 'highlight' : ''}}">{{completedCount}}</view>
      <view class="card-label">已完成</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section-title">常用功能</view>
  <view class="menu-list">
    <!-- <view class="menu-item" bindtap="goToOrderList">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-name">订单记录</text>
      </view>
      <text class="menu-arrow">></text>
    </view> -->
    <!-- <view class="menu-item" bindtap="goToOrderList" data-status="1">
      <view class="menu-left">
        <text class="menu-icon">💳</text>
        <text class="menu-name">我的优惠券</text>
      </view>
      <text class="menu-arrow">></text>
    </view> -->
    <!-- <view class="menu-item" bindtap="goToHome">
      <view class="menu-left">
        <text class="menu-icon">🏠</text>
        <text class="menu-name">返回首页</text>
      </view>
      <text class="menu-arrow">></text>
    </view> -->
    <view class="menu-item" bindtap="contact">
      <view class="menu-left">
        <text class="menu-icon">💁</text>
        <text class="menu-name">联系客服</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-name">退出登录</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
