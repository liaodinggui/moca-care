<!--pages/mine/profile-edit/index.wxml-->
<view class="edit-page">
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input class="form-input" placeholder="请输入昵称" value="{{formData.nickname}}" bindinput="onInput" data-field="nickname" maxlength="20" />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onInput" data-field="phone" maxlength="11" />
    </view>

    <!-- 头像 -->
    <view class="form-item">
      <view class="form-label">头像</view>
      <view class="avatar-upload" bindtap="chooseAvatar">
        <image class="avatar-preview" src="{{formData.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="avatar-tip">点击更换</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-btn" bindtap="saveProfile">保存</view>
</view>
