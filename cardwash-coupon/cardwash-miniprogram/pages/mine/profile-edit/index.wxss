/* pages/mine/profile-edit/index.wxss */
.edit-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
}

.avatar-upload {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  background-color: #f5f5f5;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
}

.save-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
}
