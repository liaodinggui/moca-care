<!--pages/index/index.wxml-->
<view class="index-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索洗车券...</text>
    </view>
  </view>

  <!-- 横幅广告 -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">🎉 买 10 送 1 限时优惠</text>
      <text class="banner-subtitle">超值优惠，不容错过</text>
    </view>
  </view>

  <!-- 洗车券列表 -->
  <view class="section-title">热门洗车券</view>
  <view class="coupon-list">
    <view class="coupon-card" wx:for="{{couponList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="coupon-image">
        <image src="{{item.firstImage}}" mode="aspectFill" />
      </view>
      <view class="coupon-info">
        <view class="coupon-name">{{item.name}}</view>
        <view class="merchant-name" wx:if="{{item.merchantName}}">🏪 {{item.merchantName}}</view>
        <view class="coupon-desc">{{item.description}}</view>
        <view class="coupon-footer">
          <view class="coupon-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="coupon-promotion" wx:if="{{item.buyAmount > 0 && item.sendAmount > 0}}">
            买{{item.buyAmount}}送{{item.sendAmount}}
          </view>
        </view>
        <button class="buy-btn" catchtap="goToDetail" data-id="{{item.id}}">立即购买</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{couponList.length === 0}}">
    <text class="empty-icon">🈚</text>
    <text class="empty-text">暂无可售洗车券</text>
  </view>
</view>
