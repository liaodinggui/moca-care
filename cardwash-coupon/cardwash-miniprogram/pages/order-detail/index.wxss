/* pages/order-detail/index.wxss */
.order-detail-page {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 状态区域 */
.status-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 信息区域 */
.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.value.price {
  color: #ff4d4f;
  font-weight: bold;
}

/* 通用区块 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 商品信息 */
.coupon-info {
  padding: 8rpx 0;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.coupon-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.coupon-row .desc {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 进度条 */
.progress-bar {
  height: 20rpx;
  background-color: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #1890FF, #36cfc9);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

/* 二维码区域 */
.qrcode-section {
  text-align: center;
}

.qrcode-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
}

.qrcode-loading {
  font-size: 28rpx;
  color: #999;
}

.qrcode-hint {
  font-size: 26rpx;
  color: #999;
}

/* 核销记录 */
.record-list {
  padding: 8rpx 0;
}

.record-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 26rpx;
  color: #999;
}

.record-info {
  font-size: 28rpx;
  color: #333;
}
