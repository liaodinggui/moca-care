<!--pages/order-detail/index.wxml-->
<view class="order-detail-page">
  <!-- 订单状态 -->
  <view class="status-section status-{{order.status}}">
    <view class="status-icon">
      <text wx:if="{{order.status === 0}}">💳</text>
      <text wx:if="{{order.status === 1}}">✅</text>
      <text wx:if="{{order.status === 2}}">✔️</text>
    </view>
    <view class="status-text">
      <text wx:if="{{order.status === 0}}">待付款</text>
      <text wx:if="{{order.status === 1}}">使用中</text>
      <text wx:if="{{order.status === 2}}">已完成</text>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info-section">
    <view class="info-row">
      <text class="label">订单号</text>
      <text class="value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="label">下单时间</text>
      <text class="value">{{order.createTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text class="label">支付时间</text>
      <text class="value">{{order.payTime}}</text>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="section">
    <view class="section-title">商品信息</view>
    <view class="coupon-info">
      <view class="coupon-name">{{order.couponName}}</view>
      <view class="coupon-row">
        <text class="label">单价</text>
        <text class="value">¥{{order.couponPrice}}</text>
      </view>
      <view class="coupon-row">
        <text class="label">数量</text>
        <text class="value">{{order.totalQuantity}}张
          <text class="desc" wx:if="{{order.sendQuantity > 0}}">(买{{order.paidQuantity}}送{{order.sendQuantity}})</text>
        </text>
      </view>
      <view class="coupon-row">
        <text class="label">实付</text>
        <text class="value price">¥{{order.totalAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 核销进度 -->
  <view class="section" wx:if="{{order.status === 1 || order.status === 2}}">
    <view class="section-title">核销进度</view>
    <view class="progress-bar">
      <view class="progress-inner" style="width: {{progressPercent}}%"></view>
    </view>
    <view class="progress-text">
      已核销：{{order.usedQuantity}}张 / 剩余：{{order.totalQuantity - order.usedQuantity}}张
    </view>
  </view>

  <!-- 核销二维码 -->
  <view class="section qrcode-section" wx:if="{{order.status === 1}}">
    <view class="section-title">核销二维码</view>
    <view class="qrcode-container">
      <image src="{{qrcodeUrl}}" class="qrcode-image" wx:if="{{qrcodeUrl}}" />
      <view class="qrcode-loading" wx:else>加载中...</view>
    </view>
    <view class="qrcode-hint">请出示此二维码给商家核销</view>
  </view>

  <!-- 核销记录 -->
  <view class="section" wx:if="{{writeOffRecords.length > 0}}">
    <view class="section-title">核销记录</view>
    <view class="record-list">
      <view class="record-item" wx:for="{{writeOffRecords}}" wx:key="id">
        <view class="record-time">{{item.writeOffTime}}</view>
        <view class="record-info">核销 {{item.quantity}} 张</view>
      </view>
    </view>
  </view>
</view>
