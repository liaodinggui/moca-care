/* pages/merchant/coupon-edit.wxss */
.edit-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.form-textarea {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  min-height: 200rpx;
}

/* 促销输入 */
.promotion-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.promotion-input text {
  font-size: 28rpx;
  color: #333;
}

.small-input {
  width: 120rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 图片上传 */
.image-uploader {
  width: 160rpx;
  height: 160rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.upload-btn {
  font-size: 60rpx;
  color: #1890FF;
}

.image-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background-color: #1890FF;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
}
