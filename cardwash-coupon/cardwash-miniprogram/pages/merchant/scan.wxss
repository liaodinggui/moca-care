/* pages/merchant/scan.wxss */
.scan-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.scan-container {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 扫描区域 */
.scan-area {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid #1890FF;
  border-radius: 16rpx;
  margin: 0 auto 40rpx;
  position: relative;
  overflow: hidden;
  background-color: #f5f5f5;
}

.scan-line {
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #1890FF, transparent);
  position: absolute;
  top: 0;
  animation: scanMove 2s infinite linear;
}

@keyframes scanMove {
  0% {
    top: 0;
  }
  100% {
    top: 100%;
  }
}

/* 扫描提示 */
.scan-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.hint-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #666;
}

.scan-btn {
  background-color: #1890FF;
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
  width: 100%;
  margin-bottom: 24rpx;
}

.manual-input {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: #666;
  font-size: 28rpx;
}

.input-icon {
  margin-right: 8rpx;
}
