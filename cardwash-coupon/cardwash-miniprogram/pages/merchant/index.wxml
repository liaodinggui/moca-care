<!--pages/merchant/index.wxml-->
<view class="merchant-page">
  <!-- 商家信息 -->
  <view class="merchant-card">
    <view class="shop-icon">🏪</view>
    <view class="shop-info">
      <view class="shop-name">{{merchantName}}</view>
      <view class="shop-status">营业中</view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section-title">快捷操作</view>
  <view class="quick-actions">
    <view class="action-card" bindtap="scanCode">
      <view class="action-icon">📷</view>
      <view class="action-name">扫码核销</view>
    </view>
    <view class="action-card" bindtap="manualWriteOff">
      <view class="action-icon">📝</view>
      <view class="action-name">手工录入</view>
    </view>
  </view>

  <!-- 今日数据 -->
  <view class="section-title">今日数据</view>
  <view class="stats-row">
    <view class="stat-card">
      <view class="stat-value">{{todayStats.totalSales}}</view>
      <view class="stat-label">总销售量</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{todayStats.usedWriteOff}}</view>
      <view class="stat-label">已核销</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">¥{{todayStats.revenue}}</view>
      <view class="stat-label">营业额</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section-title">功能菜单</view>
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrderList">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-name">订单管理</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToCouponList">
      <view class="menu-left">
        <text class="menu-icon">🎫</text>
        <text class="menu-name">洗车券管理</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToStats">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-name">数据统计</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <!-- <view class="menu-item" bindtap="goToHome">
      <view class="menu-left">
        <text class="menu-icon">🏠</text>
        <text class="menu-name">返回首页</text>
      </view>
      <text class="menu-arrow">></text>
    </view> -->
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <text class="menu-icon">⚙️</text>
        <text class="menu-name">店铺设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-name">退出登录</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
