<!--pages/merchant/coupon-edit.wxml-->
<view class="edit-page">
  <view class="form-section">
    <view class="form-item">
      <view class="form-label">洗车券名称</view>
      <input class="form-input" placeholder="请输入洗车券名称" value="{{formData.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-item">
      <view class="form-label">单价（元）</view>
      <input class="form-input" type="digit" placeholder="请输入单价" value="{{formData.price}}" bindinput="onInput" data-field="price" />
    </view>

    <view class="form-item">
      <view class="form-label">促销活动</view>
      <view class="promotion-input">
        <text>买</text>
        <input class="small-input" type="number" placeholder="0" value="{{formData.buyAmount}}" bindinput="onInput" data-field="buyAmount" />
        <text>送</text>
        <input class="small-input" type="number" placeholder="0" value="{{formData.sendAmount}}" bindinput="onInput" data-field="sendAmount" />
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">库存数量</view>
      <input class="form-input" type="number" placeholder="请输入库存数量" value="{{formData.stock}}" bindinput="onInput" data-field="stock" />
    </view>

    <view class="form-item">
      <view class="form-label">描述说明</view>
      <textarea class="form-textarea" placeholder="请输入洗车券详情描述" value="{{formData.description}}" bindinput="onInput" data-field="description" />
    </view>

    <view class="form-item">
      <view class="form-label">图片</view>
      <view class="image-uploader" bindtap="chooseImage">
        <view class="upload-btn">+</view>
      </view>
      <view class="image-preview" wx:if="{{imageUrl}}">
        <image src="{{imageUrl}}" mode="aspectFill" />
      </view>
    </view>
  </view>

  <view class="submit-section">
    <button class="submit-btn" bindtap="submitForm">保存</button>
  </view>
</view>
