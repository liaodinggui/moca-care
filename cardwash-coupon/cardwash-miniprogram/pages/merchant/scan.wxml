<!--pages/merchant/scan.wxml-->
<view class="scan-page">
  <view class="scan-container">
    <!-- 扫描框 -->
    <view class="scan-area">
      <view class="scan-line"></view>
    </view>
    <view class="scan-hint">
      <text class="hint-icon">📷</text>
      <text class="hint-text">对准用户订单二维码</text>
    </view>
    <button class="scan-btn" bindtap="startScan">开始扫码</button>
    <view class="manual-input" bindtap="manualInput">
      <text class="input-icon">⌨️</text>
      <text class="input-text">手动输入订单号</text>
    </view>
  </view>
</view>
