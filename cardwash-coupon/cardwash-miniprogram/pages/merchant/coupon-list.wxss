/* pages/merchant/coupon-list.wxss */
.coupon-list-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 洗车券列表 */
.coupon-list {
  display: flex;
  flex-direction: column;
}

.coupon-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.coupon-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.coupon-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.coupon-image image {
  width: 100%;
  height: 100%;
}

.coupon-info-wrap {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  overflow: hidden;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.coupon-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.coupon-status.status-1 {
  background-color: #e6f7ff;
  color: #1890FF;
}

.coupon-status.status-0 {
  background-color: #f5f5f5;
  color: #999;
}

.coupon-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.label {
  font-size: 26rpx;
  color: #999;
}

.value {
  font-size: 26rpx;
  color: #333;
}

.value.price {
  color: #ff4d4f;
  font-weight: bold;
}

.coupon-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.action-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  color: #333;
}

.action-btn.off {
  background-color: #fff7e6;
  color: #fa8c16;
}

.action-btn.on {
  background-color: #e6f7ff;
  color: #1890FF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #1890FF;
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.4);
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
}

.add-text {
  font-size: 30rpx;
}
