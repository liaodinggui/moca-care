/* pages/merchant/scan-result.wxss */
.scan-result-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 状态区域 */
.status-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 信息区域 */
.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.highlight {
  background-color: #f6ffed;
  margin: 8rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #999;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.value.price {
  color: #52c41a;
}

/* 通用区块 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 数量选择器 */
.quantity-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.qty-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #1890FF;
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.qty-btn.disabled {
  background-color: #ddd;
}

.qty-value {
  width: 120rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
}

.max-hint {
  text-align: center;
  padding: 16rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #1890FF;
  text-decoration: underline;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background-color: #1890FF;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-radius: 50rpx;
  border: none;
}

.submit-btn:disabled {
  background-color: #ccc;
}
