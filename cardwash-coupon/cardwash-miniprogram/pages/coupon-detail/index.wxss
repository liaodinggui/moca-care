/* pages/coupon-detail/index.wxss */
.detail-page {
  padding-bottom: 120rpx;
}

/* 图片轮播 */
.banner-section {
  width: 100%;
  height: 400rpx;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-swiper image {
  width: 100%;
  height: 100%;
}

/* 基本信息 */
.info-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.coupon-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.coupon-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 28rpx;
  color: #ff4d4f;
}

.price-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price-desc {
  font-size: 26rpx;
  color: #fff;
  background-color: #ff4d4f;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

.coupon-sales {
  font-size: 24rpx;
  color: #999;
}

/* 通用区块 */
.section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 数量选择器 */
.quantity-selector {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}

.qty-btn:active {
  opacity: 0.7;
}

.qty-value {
  width: 100rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 优惠券详情 */
.coupon-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.coupon-rules {
  background-color: #f5f5f5;
  padding: 24rpx;
  border-radius: 8rpx;
}

.rule-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-price .label {
  font-size: 28rpx;
  color: #666;
}

.total-price .price-symbol {
  font-size: 28rpx;
  color: #ff4d4f;
}

.total-price .price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.submit-btn {
  background-color: #1890FF;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
  border: none;
}
